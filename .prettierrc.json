{
	"arrowParens": "always",
	"bracketSpacing": true,
	"printWidth": 120,
	"semi": false,
	"singleQuote": true,
	"useTabs": true,
	"endOfLine": "lf",
	"trailingComma": "es5",
	"plugins": ["@ianvs/prettier-plugin-sort-imports"],
	"importOrder": [
		"<BUILTIN_MODULES>",
		"",
		"<THIRD_PARTY_MODULES>",
		"",
		"^@sofie-automation",
		"",
		"^[./]"
	],
	"importOrderParserPlugins": ["typescript", "jsx", "decorators-legacy"],
	"importOrderTypeScriptVersion": "5.7.0",
	"importOrderCaseSensitive": false
}
