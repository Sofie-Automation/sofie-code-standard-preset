{
	// lib and target based on https://www.npmjs.com/package/@tsconfig/node22
	"compilerOptions": {
		"module": "node20",
		"target": "es2024",
		"noImplicitAny": true,
		"moduleResolution": "Node16",
		"sourceMap": true,
		"declaration": true,
		"importHelpers": true,
		"listFiles": false,
		"traceResolution": false,
		"pretty": true,
		"lib": ["es2024", "ESNext.Array", "ESNext.Collection", "ESNext.Iterator"],
		"types": ["node"],
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"noFallthroughCasesInSwitch": true,
		"noImplicitReturns": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true
	},
	"compileOnSave": false
}
